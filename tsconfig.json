{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "noEmit": true,
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "strict": true,

    "skipLibCheck": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "verbatimModuleSyntax": true,

    "types": ["vite/client"]
  },

  "include": ["src"]
}